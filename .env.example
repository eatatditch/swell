NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Public absolute URL for the deployed app (no trailing slash).
# Production: https://swell.swellbrands.co
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — required for catering Connect onboarding + invoice payment links.
# All four must be set for Stripe features; UI shows a config banner if missing.

# Platform secret key. sk_live_… in production, sk_test_… for testing.
# Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=

# Connect OAuth client id (ca_…). Dashboard → Settings → Connect → Onboarding options.
# Used to build the Stripe Connect authorize URL on /catering/settings.
STRIPE_CONNECT_CLIENT_ID=

# Webhook signing secret (whsec_…). Created when you add the webhook endpoint at
# <NEXT_PUBLIC_APP_URL>/api/webhooks/stripe. Required events:
#   checkout.session.completed, checkout.session.async_payment_succeeded,
#   checkout.session.expired, checkout.session.async_payment_failed,
#   account.updated
# Enable "Listen to events on Connected accounts" on the endpoint.
STRIPE_WEBHOOK_SECRET=

# Gmail integration — per-user OAuth so catering managers connect their own
# inbox. Inbound mail from known contacts auto-links to the lead pipeline.

# OAuth client id and secret. Google Cloud Console → APIs & Services →
# Credentials → OAuth 2.0 Client ID (Web application). Authorized redirect URI:
#   <NEXT_PUBLIC_APP_URL>/integrations/gmail/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 32-byte hex key (64 chars) used to encrypt Gmail access + refresh tokens at
# rest with AES-256-GCM. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GMAIL_TOKEN_ENCRYPTION_KEY=

# Optional but recommended for production: Pub/Sub push topic for instant
# Gmail delivery. Without it the 5-min cron is still pulling in the
# background. Format: projects/<project-id>/topics/<topic-name>.
# Set up: enable Cloud Pub/Sub API, create the topic, grant
# gmail-api-push@system.gserviceaccount.com Publisher on the topic, then
# create a push subscription pointing at
# <NEXT_PUBLIC_APP_URL>/api/integrations/gmail/pubsub with OIDC auth.
GOOGLE_PUBSUB_TOPIC=

# Optional override of the OIDC audience the Pub/Sub push subscription
# advertises. Defaults to <NEXT_PUBLIC_APP_URL>/api/integrations/gmail/pubsub.
GOOGLE_PUBSUB_AUDIENCE=

# Optional: shared secret for the polling cron endpoint
# (/api/cron/gmail-poll). Set this in Vercel as a Cron Job secret so only
# the Vercel scheduler can trigger a sync.
CRON_SECRET=
